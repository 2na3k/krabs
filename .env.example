# LLM provider
# Supported providers: openai | anthropic | gemini | ollama | custom

# --- Ollama (local, no API key required) ---
KRABS_PROVIDER=ollama
KRABS_BASE_URL=http://127.0.0.1:8080/v1
KRABS_MODEL=Qwen3-4B-Q8_0.gguf
# KRABS_API_KEY is not needed for Ollama

# --- OpenAI ---
# KRABS_PROVIDER=openai
# KRABS_API_KEY=sk-...
# KRABS_BASE_URL=https://api.openai.com/v1
# KRABS_MODEL=gpt-4o

# --- Anthropic ---
# KRABS_PROVIDER=anthropic
# KRABS_API_KEY=sk-ant-...
# KRABS_BASE_URL=https://api.anthropic.com
# KRABS_MODEL=claude-opus-4-6

# --- Gemini ---
# KRABS_PROVIDER=gemini
# KRABS_API_KEY=...
# KRABS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# KRABS_MODEL=gemini-2.5-flash-preview

# Provider-specific aliases (used as fallback for KRABS_API_KEY)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Langfuse tracing (optional)
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=http://localhost:3000

# ── krabs-server ─────────────────────────────────────────────────────────────
# Shared secret between server and gateway (any random string)
KRABS_SERVER_SECRET_KEY=change-me-in-production
KRABS_SERVER_MAX_AGENTS=100

# ── krabs-gateway — Telegram ──────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=7123456789:AAF...

# ── krabs-gateway — WhatsApp ──────────────────────────────────────────────────
# WHATSAPP_TOKEN=EAAxxxxx...
# WHATSAPP_PHONE_NUMBER_ID=123456789
# WHATSAPP_APP_SECRET=abc123...
# WHATSAPP_VERIFY_TOKEN=my-random-verify-token
# WHATSAPP_PORT=3001

# ── krabs-gateway — Slack ─────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=abc123...
# SLACK_PORT=3002
